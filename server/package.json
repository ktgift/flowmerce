    "@google/generative-ai": "^0.24.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.6.1",
    "exceljs": "^4.4.0",
    "fuse.js": "^7.3.0",
    "mammoth": "^1.12.0",
